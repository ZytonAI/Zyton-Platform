# =============================================================
# Zyton Platform — Variables de entorno
# Copia este archivo como .env.local y rellena los valores
# NUNCA cometas .env.local al repositorio
# =============================================================

# ── Supabase (seguras para el browser — prefijo NEXT_PUBLIC_) ──
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui

# ── Solo servidor — NUNCA agregar prefijo NEXT_PUBLIC_ ──
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# ── WhatsApp Service (Stage 3) ──
# URL del whatsapp-service corriendo en tu VPS (EasyPanel)
WA_BRIDGE_URL=https://wa.tu-dominio.com
WA_BRIDGE_TOKEN=token-secreto-largo-generado-aleatoriamente
