# =============================================================
# Zyton Platform — Variables de entorno
# Copia este archivo como .env.local y rellena los valores
# NUNCA cometas .env.local al repositorio
# =============================================================

# ── Supabase (seguras para el browser — prefijo NEXT_PUBLIC_) ──
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui

# ── Solo servidor — NUNCA agregar prefijo NEXT_PUBLIC_ ──
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# ── WhatsApp Service (Stage 3) ──
# URL del whatsapp-service corriendo en tu VPS (EasyPanel)
WA_BRIDGE_URL=https://wa.tu-dominio.com
WA_BRIDGE_TOKEN=token-secreto-largo-generado-aleatoriamente

# ── AI Agents Pipeline ──
# OpenAI (GPT-4o mini) — para Elisa, Davoo y Diana
# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Apify — para Raúl (Google Places scraper)
# Obtener en: https://console.apify.com/account/integrations
APIFY_TOKEN=apify_api_...

# ── Diana — Secretaria IA ──
# Bot de Telegram (BotFather)
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Secret para verificar webhooks de Telegram (generar aleatoriamente)
TELEGRAM_WEBHOOK_SECRET=un-string-aleatorio-largo
# Secret interno para que los agentes notifiquen a Diana
DIANA_INTERNAL_SECRET=otro-string-aleatorio-largo

# ── Vercel Cron ──
# Secret que Vercel envía como "Authorization: Bearer {CRON_SECRET}"
# al cron de recordatorios de facturas. Generar aleatoriamente.
CRON_SECRET=string-aleatorio-largo-para-cron

# ── WhatsApp — normalización de teléfonos ──
# Código de país por defecto para números locales sin prefijo (ej: 57 Colombia, 52 México)
WA_DEFAULT_COUNTRY_CODE=57
