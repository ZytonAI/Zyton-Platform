# =============================================================
# Zyton WhatsApp Service — Variables de entorno
# Copia este archivo como .env y rellena los valores
# =============================================================

# Puerto HTTP del servicio
PORT=3001

# Token compartido con la plataforma:
# - La plataforma lo envía como "x-bridge-token" al llamar a este servicio
# - Este servicio lo envía como "x-webhook-secret" al llamar al webhook
# DEBE ser el mismo valor que WA_BRIDGE_TOKEN en el .env de la plataforma
BRIDGE_TOKEN=token-secreto-largo-generado-aleatoriamente

# URL del webhook de la plataforma (Next.js en Vercel)
WEBHOOK_URL=https://tu-plataforma.vercel.app/api/whatsapp/webhook

# Carpeta donde whatsapp-web.js persiste la sesión (sobrevive reinicios)
WA_SESSION_PATH=./.wwebjs_auth

# Límite de media entrante que se reenvía al webhook, en MB
# (el webhook de Vercel acepta cuerpos de hasta 4.5 MB; 3 MB crudos ≈ 4 MB en base64)
MAX_MEDIA_MB=3

# Solo si usas el Dockerfile (Chromium del sistema en vez del que descarga Puppeteer):
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
